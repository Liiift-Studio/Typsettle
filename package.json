{
	"name": "settle",
	"version": "0.0.1",
	"description": "Page-load animation where per-line tracking starts at random offsets and eases to optical equilibrium \u2014 like watching a compositor tune a paragraph",
	"type": "module",
	"main": "dist/index.cjs",
	"module": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"require": "./dist/index.cjs",
			"types": "./dist/index.d.ts"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "vite build",
		"test": "vitest",
		"test:run": "vitest run",
		"lint": "tsc --noEmit",
		"prepublishOnly": "npm run test:run && npm run build"
	},
	"peerDependencies": {
		"react": ">=17",
		"react-dom": ">=17"
	},
	"peerDependenciesMeta": {
		"react": {
			"optional": true
		},
		"react-dom": {
			"optional": true
		}
	},
	"devDependencies": {
		"@types/react": "^19.0.0",
		"@vitejs/plugin-react": "^4.0.0",
		"happy-dom": "^12.0.0",
		"react": "^19.0.0",
		"typescript": "^5.0.0",
		"vite": "^6.0.0",
		"vite-plugin-dts": "^4.0.0",
		"vitest": "^3.0.0"
	},
	"keywords": [
		"typography",
		"variable-font",
		"settle"
	],
	"author": "Quinn Keaveney <quinn@liiift.studio>",
	"license": "MIT"
}